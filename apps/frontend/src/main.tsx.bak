import ReactDOM from 'react-dom/client';
import { StrictMode } from 'react';
import App from './App';
import './styles/main.css';

// еҲӣе»ә React ж №иҠӮзӮ?const root = ReactDOM.createRoot(
  document.getElementById('root') as HTMLElement
);

// еә”з”ЁеҗҜеҠЁж—¶жЈҖжҹҘиҝһжҺҘзҠ¶жҖ?const initializeApp = async () => {
  // WebSocketиҝһжҺҘз”?StateLinkageManager з®ЎзҗҶпјҢзЎ®дҝқе®ғиў«еҲқе§ӢеҢ–
  // иҝҷдјҡи§ҰеҸ‘WebSocketиҝһжҺҘе’ҢжңҚеҠЎжЈҖжө?};

// жёІжҹ“еә”з”Ё
root.render(
  <StrictMode>
    <App />
  </StrictMode>
);

// ејҖеҸ‘зҺҜеўғи®ҫзҪ?if (process.env.NODE_ENV === 'development') {
  console.log('ZahnerFlow ејҖеҸ‘жЁЎеј?| й«ҳзә§зҺ»з’ғжҖҒи®ҫи®Ўзі»з»ҹе·Іеә”з”Ё | дәӨдә’ејҸеҠЁжҖҒж•Ҳжһңе·ІеҗҜз”Ё');

  // е…ЁеұҖй”ҷиҜҜеӨ„зҗҶ
  window.addEventListener('error', (event) => {
    console.error('еә”з”Ёй”ҷиҜҜ:', event.error?.message || String(event.error));
  });

  // жңӘеӨ„зҗҶзҡ„ Promise й”ҷиҜҜ
  window.addEventListener('unhandledrejection', (event) => {
    console.error('Promise й”ҷиҜҜ:', event.reason?.message || String(event.reason));
  });
}

// з”ҹдә§зҺҜеўғдјҳеҢ–
if (process.env.NODE_ENV === 'production') {
  // зҰҒз”ЁеҸій”®иҸңеҚ•
  document.addEventListener('contextmenu', (e) => e.preventDefault());
  
  // зҰҒз”ЁејҖеҸ‘иҖ…е·Ҙе…·еҝ«жҚ·й”®
  document.addEventListener('keydown', (e) => {
    if (
      (e.ctrlKey && e.shiftKey && e.key === 'I') ||
      (e.ctrlKey && e.shiftKey && e.key === 'J') ||
      (e.ctrlKey && e.key === 'U') ||
      (e.key === 'F12')
    ) {
      e.preventDefault();
    }
  });
}

// еә”з”ЁзүҲжң¬дҝЎжҒҜ
const APP_VERSION = '2.0.0';
const BUILD_DATE = new Date().toISOString();

console.log(`ZahnerFlow v${APP_VERSION} | жһ„е»әж—¶й—ҙ: ${BUILD_DATE} | й«ҳзә§зҺ»з’ғжҖҒи®ҫи®Ўзі»з»?| дәӨдә’ејҸеҠЁжҖҒж•Ҳжһ?| з”өеҢ–еӯҰе·ҘдҪңжөҒзј–иҫ‘еҷ?| зҺ°д»ЈеҢ–з”ЁжҲ·з•Ңйқў`);

// еңЁеә”з”ЁеҗҜеҠЁж—¶еҲқе§ӢеҢ?initializeApp();