# 环境变量配置示例

# 应用配置
NODE_ENV=development
PORT=3001

# 数据库配置
DATABASE_PATH=./data/zahnerflow.db

# 日志配置
LOG_LEVEL=info

# CORS配置
CORS_ORIGINS=http://localhost:8081,http://localhost:8083,http://localhost:3000

# 安全配置
JWT_SECRET=your-secret-key-change-in-production

# 开发模式配置
SYNC_DATABASE=true
ENABLE_DATABASE_LOGGING=true