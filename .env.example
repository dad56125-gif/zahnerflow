# ==========================================
# ZahnerFlow 环境配置
# ==========================================

# ==========================================
# 应用配置
# ==========================================
# NODE_ENV: 运行环境
#   - development: 开发模式 (详细错误信息, 热重载)
#   - production: 生产模式 (优化性能, 精简日志)
#   - test: 测试模式
NODE_ENV=development

# 后端服务端口 (前端默认8083)
PORT=3001

# ==========================================
# 日志配置
# ==========================================
# LOG_LEVEL: NestJS 全局日志级别
#   - error: 仅错误
#   - warn: 错误 + 警告
#   - log: 错误 + 警告 + 普通日志 (默认)
#   - debug: 包含调试信息
#   - verbose: 包含所有详细信息
LOG_LEVEL=log

# 模块级别日志配置 (可选, 逗号分隔)
# 格式: MODULE_NAME:LEVEL (error/warn/log/debug/verbose)
# 示例: ExecutionService:debug,ZahnerZenniumService:warn
# LOG_MODULES=

# ==========================================
# 设备服务配置
# ==========================================

# Zahner 电化学工作站
ZAHNER_FASTAPI_URL=localhost:8000
ZAHNER_SIMULATOR_URL=localhost:8001
# 设备模式: real (真实设备) 或 simulator (模拟器)
ZAHNER_MODE=real

# Furnace 高温炉
FURNACE_FASTAPI_URL=http://127.0.0.1:8011
FURNACE_SIMULATOR_URL=http://127.0.0.1:8012
# 设备模式: real (真实设备) 或 simulator (模拟器)
FURNACE_MODE=real

# MFC 质量流量控制器
MFC_FASTAPI_URL=http://127.0.0.1:8010
MFC_SIMULATOR_URL=http://127.0.0.1:8013
# 设备模式: real (真实设备) 或 simulator (模拟器)
MFC_MODE=real