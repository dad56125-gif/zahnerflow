# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=zahnerflow

# 应用配置
PORT=3001
NODE_ENV=development

# 通知系统配置
NOTIFICATION_STACK_TRACE=true
NOTIFICATION_CACHE_ENABLED=true
NOTIFICATION_CACHE_SIZE=500
NOTIFICATION_LOG_LEVEL=debug
NOTIFICATION_CONSOLE_OUTPUT=true
NOTIFICATION_PANEL_OUTPUT=true

# FastAPI设备服务配置
FASTAPI_HOST=localhost
FASTAPI_PORT=8000
FASTAPI_URL=http://localhost:8000

# WebSocket配置
WS_PORT=3001
WS_PATH=/socket.io

# 日志配置
LOG_LEVEL=debug
LOG_FORMAT=combined

# 安全配置
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=24h

# CORS配置
CORS_ORIGIN=http://localhost:3000