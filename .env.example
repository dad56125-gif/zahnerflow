# ==========================================
# ZahnerFlow 环境配置
# ==========================================

# 应用配置
NODE_ENV=development
PORT=3001

# ==========================================
# 设备服务配置
# ==========================================

# Zahner 电化学工作站
ZAHNER_FASTAPI_URL=localhost:8000
ZAHNER_SIMULATOR_URL=localhost:8001
# 设备模式: real (真实设备) 或 simulator (模拟器)
ZAHNER_MODE=simulator

# MFC 质量流量控制器
MFC_FASTAPI_URL=http://127.0.0.1:8010

# Furnace 高温炉
FURNACE_FASTAPI_URL=http://127.0.0.1:8011

# ==========================================
# 邮件通知配置 (可选)
# ==========================================
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=