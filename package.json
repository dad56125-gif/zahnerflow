{
  "name": "zahnerflow-monorepo",
  "version": "1.0.0",
  "description": "ZahnerFlow 电化学工作流管理系统",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter backend start:dev\"",
    "build": "pnpm --filter frontend build && pnpm --filter backend build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:frontend": "vitest run test/code/frontend",
    "test:backend": "vitest run test/code/backend",
    "test:integration": "vitest run test/code/integration",
    "test:e2e": "vitest run test/code/e2e",
    "test:api": "vitest run test/code/integration/api-integration.test.ts",
    "test:websocket": "vitest run test/code/integration/websocket.test.ts",
    "test:report": "node test/scripts/generate-report.js",
    "test:clean": "node test/scripts/clean-results.js",
    "test:validate": "node test/scripts/validate-tests.js",
    "test:performance": "node test/scripts/performance-test.js",
    "test:parallel": "vitest run --reporter=verbose --maxConcurrency=4",
    "test:debug": "vitest --inspect-brk",
    "test:changed": "vitest run --changed",
    "test:fail-fast": "vitest run --fail-fast",
    "test:update-snapshots": "vitest run --update-snapshots",
    "lint": "pnpm --recursive lint",
    "type-check": "pnpm --recursive type-check",
    "clean": "pnpm --recursive clean",
    "setup": "node scripts/setup.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^0.34.0",
    "@vitest/ui": "^0.34.0",
    "concurrently": "^8.2.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "electrochemistry",
    "workflow",
    "zahner",
    "gamry",
    "lab-automation"
  ],
  "author": "ZahnerFlow Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/zahnerflow.git"
  }
}